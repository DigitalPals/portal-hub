{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digitalpals.dev/portal-hub/contracts/v2/sync-v2-response.schema.json",
  "title": "Portal Hub API v2 sync response",
  "type": "object",
  "required": ["api_version", "generated_at", "services"],
  "properties": {
    "api_version": { "const": 2 },
    "generated_at": { "type": "string", "format": "date-time" },
    "services": {
      "type": "object",
      "propertyNames": {
        "enum": ["hosts", "settings", "snippets", "vault"]
      },
      "additionalProperties": {
        "type": "object",
        "required": ["revision", "payload", "tombstones"],
        "properties": {
          "revision": { "type": "string", "minLength": 1 },
          "payload": {},
          "tombstones": {
            "anyOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "object" }
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
