{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digitalpals.dev/portal-hub/contracts/v2/session-delete-response.schema.json",
  "title": "Portal Hub API v2 session delete response",
  "type": "object",
  "required": ["api_version", "session_id", "deleted", "process_signaled"],
  "properties": {
    "api_version": { "const": 2 },
    "session_id": { "type": "string", "format": "uuid" },
    "deleted": { "type": "boolean" },
    "process_signaled": { "type": "boolean" }
  },
  "additionalProperties": true
}
